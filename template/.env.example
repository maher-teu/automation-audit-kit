# ── Required ─────────────────────────────────────────────────────────────────
# Your Anthropic API key (console.anthropic.com -> API keys). Powers the agent.
ANTHROPIC_API_KEY=

# Supabase project (free tier is fine): supabase.com -> New project.
# Then run db/schema.sql in the SQL editor (SETUP.md walks you through it).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# A private password for YOUR leads page (/leads?k=...). Pick anything long.
LEADS_KEY=

# ── Optional (each one unlocks a feature, all safe to leave empty) ───────────
# Resend (resend.com, free tier): emails you every new lead + emails the lead
# their map link. Leave empty = no emails, leads page still catches everything.
RESEND_API_KEY=
# Where lead notifications go (your email). Required only if RESEND_API_KEY set.
NOTIFY_EMAIL=
# "From" address for emails. Resend gives you onboarding@resend.dev to start.
FROM_EMAIL=onboarding@resend.dev

# GoHighLevel inbound webhook URL: new leads (name/email/phone + their map link)
# land straight in your GHL pipeline. Workflows -> Inbound Webhook -> paste URL.
GHL_WEBHOOK_URL=

# GoHighLevel API (recommended if you use GHL): every lead lands as a CONTACT in
# your GHL the moment they type their email (tagged audit-started), the full
# interview + map link land in the contact's NOTES, and completed leads
# automatically get their map by EMAIL (and SMS if they left a phone), sent from
# your GHL. Key: GHL -> Settings -> Integrations -> Private Integrations (scopes:
# contacts + conversations/message). Location ID: Settings -> Business Profile.
# Email needs your GHL sending domain set up; SMS needs a phone number in GHL.
GHL_API_KEY=
GHL_LOCATION_ID=

# Telegram ping per lead (free, 2 min): message @BotFather -> /newbot -> paste the
# token. Then message your new bot once, and get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
